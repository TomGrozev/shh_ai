{
  "name": "shh_ai",
  "image": "ghcr.io/tomgrozev/devcontainer-elixir:elixir-1.19.4-otp-28.5.0.1@sha256:e463b98d2ec897f6c760b4a00bccb900911029d690ed22473aace3852d6adf7e",
  "remoteEnv": {
    "MIX_BUILD_PATH": "/workspace/_build/devcontainer",
    "MIX_DEPS_PATH": "/workspace/deps/devcontainer"
  },
  "containerEnv": {
    "DEVCONTAINER": "true",
    "EDITOR": "nvim",
    "VISUAL": "nvim"
  },
  "remoteUser": "dev",
  "userEnvProbe": "none",
  "forwardPorts": [4000, 40966],
  "portsAttributes": {
    "4000": {
      "label": "Phoenix",
      "onAutoForward": "notify"
    },
    "40966": {
      "label": "Opencode",
      "onAutoForward": "notify"
    }
  },
  "mounts": [
    "source=shhai-commandhistory,target=/commandhistory,type=volume",
    "type=tmpfs,target=${localEnv:HOME}/.gnupg,size=10Mi"
  ],
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "postCreateCommand": "mix deps.get",
  "postStartCommand": "bash -c 'nohup opencode serve --port 40966 > /tmp/opencode-serve.log 2>&1 & disown'"
}
